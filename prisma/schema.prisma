generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  KARYAWAN
}

enum Division {
  TABUNG
  ASESORIS
  PACKING
}

enum AuditAction {
  CREATE
  UPDATE
  SOFT_DELETE
  RESTORE
}

enum PerformanceAuditTable {
  PERFORMANCE_RECORD
  PERFORMANCE_RECORD_ITEM
}

model User {
  id                   String                @id @default(uuid()) @db.Uuid
  name                 String
  email                String                @unique
  emailVerified        DateTime?             @map("email_verified")
  image                String?
  password             String
  role                 UserRole              @default(KARYAWAN)
  deletedAt            DateTime?             @map("deleted_at")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  employee             Employee?
  accounts             Account[]
  sessions             Session[]
  createdRecords       PerformanceRecord[]   @relation("PerformanceRecordCreatedBy")
  createdKasbons       KasbonRecord[]        @relation("KasbonCreatedBy")
  performanceAuditLogs PerformanceAuditLog[] @relation("PerformanceAuditActor")

  @@index([role])
  @@index([deletedAt])
  @@map("users")
}

model Account {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String   @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Product {
  id          String                  @id @default(uuid()) @db.Uuid
  namaProduk  String                  @unique @map("nama_produk")
  divisi      Division
  upahSatuan  Int                     @map("upah_satuan")
  deletedAt   DateTime?               @map("deleted_at")
  createdAt   DateTime                @default(now()) @map("created_at")
  updatedAt   DateTime                @updatedAt @map("updated_at")
  recordItems PerformanceRecordItem[]

  @@index([divisi])
  @@index([deletedAt])
  @@map("products")
}

model Employee {
  id                 String              @id @default(uuid()) @db.Uuid
  userId             String              @unique @map("user_id") @db.Uuid
  nama               String
  divisi             Division
  kategori           String
  deletedAt          DateTime?           @map("deleted_at")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  user               User                @relation(fields: [userId], references: [id], onDelete: Restrict)
  performanceRecords PerformanceRecord[]
  kasbonRecords      KasbonRecord[]

  @@index([nama])
  @@index([divisi])
  @@index([deletedAt])
  @@map("employees")
}

model PerformanceRecord {
  id          String                  @id @default(uuid()) @db.Uuid
  employeeId  String                  @map("employee_id") @db.Uuid
  tanggal     DateTime                @db.Date
  totalUpah   Int                     @map("total_upah")
  createdById String                  @map("created_by") @db.Uuid
  deletedAt   DateTime?               @map("deleted_at")
  createdAt   DateTime                @default(now()) @map("created_at")
  updatedAt   DateTime                @updatedAt @map("updated_at")
  employee    Employee                @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  createdBy   User                    @relation("PerformanceRecordCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  items       PerformanceRecordItem[]
  auditLogs   PerformanceAuditLog[]

  @@index([employeeId])
  @@index([tanggal])
  @@index([createdById])
  @@index([deletedAt])
  @@map("performance_records")
}

model PerformanceRecordItem {
  id        String            @id @default(uuid()) @db.Uuid
  recordId  String            @map("record_id") @db.Uuid
  productId String            @map("product_id") @db.Uuid
  qty       Int
  upah      Int
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")
  record    PerformanceRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  product   Product           @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([recordId])
  @@index([productId])
  @@map("performance_record_items")
}

model PerformanceAuditLog {
  id          String                @id @default(uuid()) @db.Uuid
  recordId    String?               @map("record_id") @db.Uuid
  targetTable PerformanceAuditTable @map("target_table")
  targetId    String                @map("target_id") @db.Uuid
  action      AuditAction
  oldValues   Json?                 @map("old_values")
  newValues   Json?                 @map("new_values")
  actorUserId String?               @map("actor_user_id") @db.Uuid
  createdAt   DateTime              @default(now()) @map("created_at")
  record      PerformanceRecord?    @relation(fields: [recordId], references: [id], onDelete: SetNull)
  actorUser   User?                 @relation("PerformanceAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([recordId])
  @@index([targetTable, targetId])
  @@index([actorUserId])
  @@index([createdAt])
  @@map("performance_audit_logs")
}

model KasbonRecord {
  id          String    @id @default(uuid()) @db.Uuid
  employeeId  String    @map("employee_id") @db.Uuid
  tanggal     DateTime  @db.Date
  nominal     Int
  keterangan  String?
  createdById String    @map("created_by") @db.Uuid
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  createdBy   User      @relation("KasbonCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  
  @@index([employeeId])
  @@index([tanggal])
  @@index([deletedAt])
  @@map("kasbon_records")
}
